# Copy this file to .env, or let ./start.sh create one automatically.

COMPOSE_PROJECT_NAME=media-server

# The setup script fills these with the current user and detected timezone.
PUID=1000
PGID=1000
TZ=Etc/UTC

# Host paths. Relative paths are resolved from this repository.
CONFIG_DIR=./data
MEDIA_DIR=./media
DOWNLOADS_DIR=./downloads

# Host ports. Change these only when a port is already in use.
JELLYFIN_PORT=8096
SEERR_PORT=5055
QBITTORRENT_PORT=8080
TORRENT_PORT=6881
PROWLARR_PORT=9696
FLARESOLVERR_PORT=8191
SONARR_PORT=8989
RADARR_PORT=7878
LIDARR_PORT=8686
BAZARR_PORT=6767
METUBE_PORT=8081
JDOWNLOADER_PORT=5800
UPTIME_KUMA_PORT=3001
SPEEDTEST_PORT=8765
HOME_ASSISTANT_PORT=8123
NOTIFIARR_PORT=5454

# ./start.sh generates this automatically for new installations.
SPEEDTEST_APP_KEY=
SPEEDTEST_SCHEDULE=0 */6 * * *

# Required only by the optional automation profile.
UN_SONARR_API_KEY=
UN_RADARR_API_KEY=
UN_LIDARR_API_KEY=
NOTIFIARR_API_KEY=
