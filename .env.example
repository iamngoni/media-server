# Media Server Environment Variables
# ─────────────────────────────────────
# Copy this file to .env and fill in your values

# Common
PUID=1000
PGID=1000
TZ=Africa/Johannesburg

# Host paths
# ─────────────────────────────────────
# Root of your media library (Movies/Series/Anime/Animations/Music live under here).
# On macOS this will usually be /Volumes/<external-drive-name>.
MEDIA_DIR=/mnt/media
# Where metube/jdownloader save files (user home is typical: /home/<user>/downloads)
DOWNLOADS_DIR=/home/user/downloads

# Kompressor - cloned next to this repo by default
KOMPRESSOR_DIR=../kompressor
KOMPRESSOR_DATA_DIR=./kompressor/data
KOMPRESSOR_TEMP_DIR=./kompressor/temp
KOMPRESSOR_CONFIG=../kompressor/config.docker.toml
KOMPRESSOR_TEMPLATES=../kompressor/templates
KOMPRESSOR_LOG_LEVEL=info

# Nexus - cloned next to this repo by default
NEXUS_DIR=../nexus
NEXUS_ENV_FILE=../nexus/.env
NEXUS_PORT=3000
NEXUS_HOST_IP=localhost
NEXUS_WEATHER_LOCATION=Sandton
NEXUS_QBIT_URL=http://host.docker.internal:8080
NEXUS_JELLYFIN_URL=http://host.docker.internal:8096
NEXUS_SONARR_URL=http://host.docker.internal:8989
NEXUS_RADARR_URL=http://host.docker.internal:7878
NEXUS_SPEEDTEST_URL=http://host.docker.internal:8765
NEXUS_LOG_LEVEL=info
OPENCLAW_LOG_DIR=./openclaw/logs

# Unpackerr - Arr API Keys
UN_SONARR_API_KEY=your_sonarr_api_key
UN_RADARR_API_KEY=your_radarr_api_key
UN_LIDARR_API_KEY=your_lidarr_api_key

# Notifiarr
NOTIFIARR_API_KEY=your_notifiarr_api_key

# Speedtest Tracker
# Generate with: echo "base64:$(openssl rand -base64 32)"
SPEEDTEST_APP_KEY=base64:generate_with_openssl_rand
