# Media Server Environment Variables
# ─────────────────────────────────────
# Copy this file to .env and fill in your values

# Common
PUID=1000
PGID=1000
TZ=Africa/Johannesburg

# Host paths
# ─────────────────────────────────────
# Root of your media library (Movies/Series/Anime/Animations/Music live under here)
MEDIA_DIR=/mnt/media
# Where metube/jdownloader save files (user home is typical: /home/<user>/downloads)
DOWNLOADS_DIR=/home/user/downloads

# Kompressor (transcoder)
# ─────────────────────────────────────
# Directory containing data/, templates/, and config.docker.toml
KOMPRESSOR_DIR=/home/user/kompressor
# Scratch space for in-progress transcodes (put on fast/SSD storage)
KOMPRESSOR_TEMP_DIR=/home/user/.kompressor-temp
# Host GID of the `render` group (run `getent group render` to find it)
RENDER_GID=992

# Nexus (homelab dashboard)
# ─────────────────────────────────────
NEXUS_ENV_FILE=/home/user/nexus/.env
OPENCLAW_LOGS_DIR=/home/user/.openclaw/logs
CLAWDBOT_SOCKET_DIR=/tmp/clawdbot

# Homepage - comma-separated list of allowed hosts (IPs/hostnames + port)
HOMEPAGE_ALLOWED_HOSTS=localhost:3000

# Unpackerr - Arr API Keys
UN_SONARR_API_KEY=your_sonarr_api_key
UN_RADARR_API_KEY=your_radarr_api_key
UN_LIDARR_API_KEY=your_lidarr_api_key

# Notifiarr
NOTIFIARR_API_KEY=your_notifiarr_api_key

# Speedtest Tracker
# Generate with: echo "base64:$(openssl rand -base64 32)"
SPEEDTEST_APP_KEY=base64:generate_with_openssl_rand
